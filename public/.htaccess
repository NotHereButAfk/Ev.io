# ── KYX.IO static hosting (Hostinger / Apache) ──────────────────────────────

# Correct MIME types for game assets
AddType model/gltf-binary .glb
AddType application/wasm .wasm
AddType application/javascript .js
AddType application/json .json

# Gzip / deflate text + binary-ish assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache hashed build assets hard; never cache the HTML entry point
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType model/gltf-binary "access plus 1 year"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|glb|png|jpg|jpeg|svg|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Single-page fallback: send unknown paths to index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
